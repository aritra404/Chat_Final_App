<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@drawable/ic_app_new"
        android:label="@string/app_name"
        android:roundIcon="@drawable/ic_app_new"
        android:supportsRtl="true"
        android:theme="@style/Theme.New_Chat"
        tools:targetApi="31">

        <service
            android:name=".service.MyFirebaseMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

        <meta-data
            android:name="com.google.firebase.messaging.default_notification_channel_id"
            android:value="@string/default_notification_channel_id" />

        <activity
            android:name=".ui.profile.ProfileEditActivity"
            android:exported="false"
            android:theme="@style/Theme.New_Chat" />
        <activity
            android:name=".ui.main.MainActivity"
            android:exported="false" />
        <activity
            android:name=".ui.chat.ChatScreen"
            android:exported="false" />
        <activity
            android:name=".ui.story.StoryViewerActivity"
            android:exported="false" />
        <activity
            android:name=".ui.story.StoryUploadActivity"
            android:exported="false" />
        <activity
            android:name=".ui.auth.LoginActivity"
            android:exported="true"
            android:theme="@style/Theme.New_Chat">

        </activity>

        <activity
            android:name=".ui.splash.Splash_Activity"
            android:theme="@style/Theme.AppCompat.DayNight.NoActionBar"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ui.auth.SignUpActivity"
            android:exported="true"
            android:theme="@style/Theme.New_Chat"></activity>
        <activity
            android:name=".ui.main.ShowUsersActivity"
            android:exported="true"
            android:theme="@style/Theme.New_Chat" />
    </application>

</manifest>